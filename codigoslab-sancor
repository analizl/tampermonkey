// ==UserScript==
// @name         Códigos Laboratorio - Sancor
// @namespace    http://tampermonkey.net/
// @version      2.0
// @description  Carga automática códigos Laboratorio Sancor
// @author       Diagnosis
// @match        https://autorizacionesprestadoresui.sancorsalud.com.ar/*
// @grant        GM_xmlhttpRequest
// @connect      localhost
// @connect      srapp.diagnosis.com.ar
// @run-at       document-end
// ==/UserScript==

(function() {
    'use strict';

    let datosMedicosTemporales = {
        codigoDiagnostico: null,
        medicoCodigo: null,
        medicoApellido: null
    };

    // Función auxiliar para pausar el script
    const sleep = (ms) => new Promise(resolve => setTimeout(resolve, ms));

    function formatearCodigoPrestacion(codigoCrudo) {
        let limpio = codigoCrudo.trim();
        if (limpio.length === 6) {
            return limpio;
        }

        return '66' + limpio.padStart(4, '0');
    }

    function escribirEnInput(inputElement, valor) {
        inputElement.value = valor;
        inputElement.dispatchEvent(new Event('input', { bubbles: true }));
        inputElement.dispatchEvent(new Event('change', { bubbles: true }));
    }

    function mostrarErrorCodigoFaltante() {
        const modalViejo = document.getElementById('tm-modal-error-container');
        if (modalViejo) modalViejo.remove();

        const contenedor = document.createElement('div');
        contenedor.id = 'tm-modal-error-container';
        contenedor.style.position = 'fixed';
        contenedor.style.top = '0';
        contenedor.style.left = '0';
        contenedor.style.width = '100vw';
        contenedor.style.height = '100vh';
        contenedor.style.backgroundColor = 'rgba(0, 0, 0, 0.5)';
        contenedor.style.display = 'flex';
        contenedor.style.justifyContent = 'center';
        contenedor.style.alignItems = 'center';
        contenedor.style.zIndex = '99999';
        contenedor.style.fontFamily = 'Roboto, "Helvetica Neue", sans-serif';

        const modal = document.createElement('div');
        modal.style.backgroundColor = '#ffffff';
        modal.style.width = '450px';
        modal.style.maxWidth = '90%';
        modal.style.borderRadius = '12px';
        modal.style.boxShadow = '0px 8px 24px rgba(0,0,0,0.3)';
        modal.style.overflow = 'hidden';

        const header = document.createElement('div');
        header.style.backgroundColor = '#dc3545';
        header.style.color = 'white';
        header.style.padding = '16px 20px';
        header.style.fontWeight = 'bold';
        header.style.fontSize = '18px';
        header.innerText = '⚠️ Código Requerido Faltante';

        const body = document.createElement('div');
        body.style.padding = '20px';
        body.style.color = '#333333';
        body.style.fontSize = '14px';
        body.style.lineHeight = '1.6';

        const mensaje = document.createElement('p');
        mensaje.style.margin = '0 0 20px 0';
        mensaje.style.fontSize = '15px';
        mensaje.innerHTML = 'El código <strong>2003</strong> no se encuentra en la ficha de este afiliado.<br><br>Por favor, guardalo primero en el <strong>SIP</strong> y luego vuelva para realizar la carga automática de códigos.';
        body.appendChild(mensaje);

        const btnCerrar = document.createElement('button');
        btnCerrar.type = 'button';
        btnCerrar.innerText = 'Entendido';
        btnCerrar.style.width = '100%';
        btnCerrar.style.padding = '12px';
        btnCerrar.style.backgroundColor = '#dc3545';
        btnCerrar.style.color = 'white';
        btnCerrar.style.border = 'none';
        btnCerrar.style.borderRadius = '6px';
        btnCerrar.style.cursor = 'pointer';
        btnCerrar.style.fontWeight = 'bold';
        btnCerrar.style.fontSize = '14px';

        btnCerrar.addEventListener('click', () => {
            document.body.removeChild(contenedor);
            datosMedicosTemporales = { codigoDiagnostico: null, medicoCodigo: null, medicoApellido: null };
        });

        body.appendChild(btnCerrar);
        modal.appendChild(header);
        modal.appendChild(body);
        contenedor.appendChild(modal);
        document.body.appendChild(contenedor);
    }

    function mostrarModalErrores(codigosFallidos) {
        const modalViejo = document.getElementById('tm-modal-error-container');
        if (modalViejo) modalViejo.remove();

        // Contenedor principal
        const contenedor = document.createElement('div');
        contenedor.id = 'tm-modal-error-container';
        contenedor.style.position = 'fixed';
        contenedor.style.top = '0';
        contenedor.style.left = '0';
        contenedor.style.width = '100vw';
        contenedor.style.height = '100vh';
        contenedor.style.backgroundColor = 'rgba(0, 0, 0, 0.5)';
        contenedor.style.display = 'flex';
        contenedor.style.justifyContent = 'center';
        contenedor.style.alignItems = 'center';
        contenedor.style.zIndex = '99999';
        contenedor.style.fontFamily = 'Roboto, "Helvetica Neue", sans-serif';

        // Caja del Modal
        const modal = document.createElement('div');
        modal.style.backgroundColor = '#ffffff';
        modal.style.width = '480px';
        modal.style.maxWidth = '90%';
        modal.style.borderRadius = '12px';
        modal.style.boxShadow = '0px 8px 24px rgba(0,0,0,0.3)';
        modal.style.overflow = 'hidden';
        modal.style.animation = 'fadeIn 0.2s ease-out';

        // Encabezado
        const header = document.createElement('div');
        const todoOk = codigosFallidos.length === 0;
        header.style.backgroundColor = todoOk ? '#28a745' : '#dc3545';
        header.style.color = 'white';
        header.style.padding = '16px 20px';
        header.style.fontWeight = 'bold';
        header.style.fontSize = '18px';
        header.innerText = todoOk ? '¡Proceso Exitoso! 🎉' : '⚠️ Códigos no cargados';

        // Cuerpo del modal
        const body = document.createElement('div');
        body.style.padding = '20px';
        body.style.color = '#333333';
        body.style.fontSize = '14px';
        body.style.lineHeight = '1.5';

        if (todoOk) {
            body.innerHTML = '<p style="margin:0; font-size: 15px; text-align:center;">Se procesaron y cargaron todas las prácticas médicas con éxito en el sistema.</p>';
        } else {
            body.innerHTML = '<p style="margin:0 0 12px 0; font-weight: 500;">Las siguientes prácticas no se pudieron auto-completar y requieren carga manual:</p>';

            // Lista de códigos
            const ul = document.createElement('ul');
            ul.style.margin = '0 0 20px 0';
            ul.style.paddingLeft = '20px';
            ul.style.maxHeight = '180px';
            ul.style.overflowY = 'auto';
            ul.style.border = '1px solid #eeeeee';
            ul.style.paddingTop = '8px';
            ul.style.paddingBottom = '8px';
            ul.style.borderRadius = '6px';
            ul.style.backgroundColor = '#f9f9f9';

            codigosFallidos.forEach(err => {
                const li = document.createElement('li');
                li.style.marginBottom = '6px';
                li.style.color = '#555555';
                li.innerHTML = `<strong>${err.split(' ')[0]}</strong> ${err.substring(err.indexOf(' '))}`;
                ul.appendChild(li);
            });
            body.appendChild(ul);

            // Botón de Copiar al Portapapeles (Solo si hay errores)
            const btnCopiar = document.createElement('button');
            btnCopiar.type = 'button';
            btnCopiar.innerText = '📋 Copiar códigos fallidos';
            btnCopiar.style.width = '100%';
            btnCopiar.style.marginBottom = '10px';
            btnCopiar.style.padding = '10px';
            btnCopiar.style.backgroundColor = '#6c757d';
            btnCopiar.style.color = 'white';
            btnCopiar.style.border = 'none';
            btnCopiar.style.borderRadius = '6px';
            btnCopiar.style.cursor = 'pointer';
            btnCopiar.style.fontWeight = '500';
            btnCopiar.style.transition = 'background-color 0.1s';

            btnCopiar.addEventListener('click', () => {
                const textoACopiar = codigosFallidos.map(e => e.split(',')).join('\n');

                const campoTemporal = document.createElement('textarea');
                campoTemporal.value = textoACopiar;
                campoTemporal.style.position = 'fixed';
                campoTemporal.style.top = '0';
                campoTemporal.style.left = '0';
                campoTemporal.style.opacity = '0';
                document.body.appendChild(campoTemporal);

                // Seleccionar el contenido y copiarlo al portapapeles
                campoTemporal.focus();
                campoTemporal.select();

                try {
                    const exito = document.execCommand('copy');
                    if (exito) {
                        btnCopiar.innerText = '✅ ¡Copiado!';
                        btnCopiar.style.backgroundColor = '#28a745';
                    } else {
                        btnCopiar.innerText = '❌ Error al copiar';
                    }
                } catch (err) {
                    console.error("Error con execCommand:", err);
                    btnCopiar.innerText = '❌ No permitido';
                }

                // Eliminar el elemento temporal
                document.body.removeChild(campoTemporal);

                setTimeout(() => {
                    btnCopiar.innerText = '📋 Copiar códigos fallidos';
                    btnCopiar.style.backgroundColor = '#6c757d';
                }, 2000);
            });
            body.appendChild(btnCopiar);
        }

        // Botón Cerrar
        const btnCerrar = document.createElement('button');
        btnCerrar.type = 'button';
        btnCerrar.innerText = 'Cerrar';
        btnCerrar.style.width = '100%';
        btnCerrar.style.padding = '10px';
        btnCerrar.style.backgroundColor = '#007bff';
        btnCerrar.style.color = 'white';
        btnCerrar.style.border = 'none';
        btnCerrar.style.borderRadius = '6px';
        btnCerrar.style.cursor = 'pointer';
        btnCerrar.style.fontWeight = 'bold';

        btnCerrar.addEventListener('click', async () => {
            document.body.removeChild(contenedor);
            console.log("[Tampermonkey] Modal cerrado. Iniciando segunda fase de carga...");

            await sleep(300);

            // Se ejecuta la carga de Diagnóstico y Médico
            if (datosMedicosTemporales.codigoDiagnostico) {
                await automatizarDiagnostico(datosMedicosTemporales.codigoDiagnostico);
                await sleep(400);
            }

            if (datosMedicosTemporales.medicoCodigo && datosMedicosTemporales.medicoApellido) {
                await automatizarPrescriptor(datosMedicosTemporales.medicoCodigo, datosMedicosTemporales.medicoApellido);
            }

            datosMedicosTemporales = { codigoDiagnostico: null, medicoCodigo: null, medicoApellido: null };
        });

        body.appendChild(btnCerrar);
        modal.appendChild(header);
        modal.appendChild(body);
        contenedor.appendChild(modal);
        document.body.appendChild(contenedor);
    }

    async function modificarCantidadDeCodigo(codigoFormateado, cantidadDeseada) {
        if (cantidadDeseada <= 1) return;

        console.log(`[Tampermonkey] Buscando la fila para el código ${codigoFormateado}...`);
        await sleep(800);

        const filas = document.querySelectorAll('mat-row');
        let filaEncontrada = null;

        for (let fila of filas) {
            const celdaCodigo = fila.querySelector('.mat-column-codigo_prestacion, .mat-column-prestacion_sancor, .mat-column-prestacion');
            if (celdaCodigo && celdaCodigo.textContent.includes(codigoFormateado)) {
                filaEncontrada = fila;
                break;
            }
        }

        if (!filaEncontrada) {
            console.error(`[Tampermonkey] No se pudo encontrar la fila para el código: ${codigoFormateado}`);
            return;
        }

        let disparadorSelect = filaEncontrada.querySelector('.mat-select-trigger');

        if (!disparadorSelect) {
            disparadorSelect = filaEncontrada.querySelector('mat-select');
        }

        if (!disparadorSelect) {
            console.error("[Tampermonkey] No se encontró ningún elemento clickable de cantidad en esta fila.");
            return;
        }

        disparadorSelect.click();

        let panelSelect = null;
        for (let i = 0; i < 30; i++) {
            panelSelect = document.querySelector('.mat-select-panel, .mat-autocomplete-panel, cdk-overlay-pane');
            if (panelSelect && panelSelect.querySelector('mat-option')) {
                break;
            }
            await sleep(100);
        }

        if (!panelSelect) {
            console.error("[Tampermonkey] El panel de opciones de cantidad nunca se abrió en el DOM global.");
            return;
        }

        const opciones = panelSelect.querySelectorAll('mat-option');
        let opcionCorrecta = null;

        for (let opt of opciones) {
            if (opt.textContent.trim() === String(cantidadDeseada)) {
                opcionCorrecta = opt;
                break;
            }
        }

        if (opcionCorrecta) {
            console.log(`[Tampermonkey] Haciendo clic en la opción de cantidad: ${cantidadDeseada}`);
            opcionCorrecta.click();
        } else {
            console.warn(`[Tampermonkey] No se encontró el número ${cantidadDeseada}. Clickeando primera alternativa.`);
            if (opciones.length > 0) opciones[0].click();
        }

        await sleep(600);
    }

    async function automatizarEfectorYEspecialidad() {
        console.log("[Tampermonkey] Evaluando campo Efector...");

        const inputEfector = document.querySelector('input[formcontrolname="efectorControl"]');
        if (!inputEfector) {
            console.warn("[Tampermonkey] No se encontró el campo input de Efector.");
            return;
        }

        inputEfector.focus();
        escribirEnInput(inputEfector, " ");
        await sleep(100);
        escribirEnInput(inputEfector, "");

        let panelEfector = null;
        for (let i = 0; i < 20; i++) {
            panelEfector = document.querySelector('.mat-autocomplete-panel');
            if (panelEfector) break;
            await sleep(100);
        }

        if (!panelEfector) {
            console.log("[Tampermonkey] No se abrió ningún panel de opciones para Efector.");
            return;
        }

        // Cuantas opciones hay
        const opcionesEfector = panelEfector.querySelectorAll('mat-option');
        console.log(`[Tampermonkey] Opciones encontradas en Efector: ${opcionesEfector.length}`);

        // Si hay EXACTAMENTE una sola opción, la elegimos automáticamente
        if (opcionesEfector.length === 1) {
            const unicaOpcion = opcionesEfector[0];
            console.log(`[Tampermonkey] Una sola opción detectada (${unicaOpcion.textContent.trim()}). Seleccionando...`);

            unicaOpcion.click();
            inputEfector.blur();

            await sleep(800);

            //await automatizarEspecialidadFila();
        } else {
            console.log("[Tampermonkey] Existen múltiples opciones o ninguna. Se deja el campo vacío.");
            inputEfector.blur();
            inputEfector.dispatchEvent(new KeyboardEvent('keydown', { key: 'Escape', code: 'Escape', bubbles: true }));
        }
    }

