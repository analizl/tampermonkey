            await sleep(100);
        }

        if (!panelSelect) {
            console.warn("[Tampermonkey] No se abrió el panel de opciones de Especialidad.");
            return;
        }

        const opcionesEspecialidad = panelSelect.querySelectorAll('mat-option');
