    async function automatizarMarcaGuardia() {
        console.log("[Tampermonkey] Configurando ámbito de atención (Marca de guardia)...");

        const componenteGuardia = document.querySelector('app-marca-guardia');
        if (!componenteGuardia) {
            console.warn("[Tampermonkey] No se encontró el componente <app-marca-guardia> en pantalla.");
            return;
        }

        let disparadorSelect = componenteGuardia.querySelector('.mat-select-trigger');
        if (!disparadorSelect) {
            disparadorSelect = componenteGuardia.querySelector('mat-select');
        }

        if (!disparadorSelect) {
            console.error("[Tampermonkey] No se encontró el selector de Marca de guardia.");
            return;
        }

        disparadorSelect.click();

        let panelSelect = null;
        for (let i = 0; i < 20; i++) {
            panelSelect = document.querySelector('.mat-select-panel, cdk-overlay-pane');
            if (panelSelect && panelSelect.querySelector('mat-option')) break;
            await sleep(100);
        }

        if (!panelSelect) {
            console.error("[Tampermonkey] No se abrió el panel de opciones de Marca de guardia.");
            return;
        }

        // Se selecciona la opcion Programada
        const opciones = panelSelect.querySelectorAll('mat-option');
        let opcionProgramada = null;

        for (let opt of opciones) {
            if (opt.textContent.trim().toLowerCase().includes('programada')) {
                opcionProgramada = opt;
                break;
            }
        }

        if (opcionProgramada) {
            console.log("[Tampermonkey] Seleccionando opción 'Programada'.");
            opcionProgramada.click();
        } else {
            console.warn("[Tampermonkey] No se encontró la opción 'Programada' en la lista flotante.");
            const overlay = document.querySelector('.cdk-overlay-backdrop');
            if (overlay) overlay.click();
        }

        await sleep(400);
    }

    async function automatizarDiagnostico(codigoDiagnostico) {
        if (!codigoDiagnostico) {
            console.log("[Tampermonkey] La API no devolvió ningún diagnóstico.");
            return;
        }

        const limpioCie = String(codigoDiagnostico).trim().toUpperCase();
        console.log(`[Tampermonkey] Buscando el diagnóstico: ${limpioCie}...`);

        const componenteDiag = document.querySelector('app-diagnostico');
        const inputDiag = componenteDiag ? componenteDiag.querySelector('input[formcontrolname="descripcion"]') : null;

        if (!inputDiag) {
            console.warn("[Tampermonkey] No se localizó el cuadro de texto para Diagnóstico.");
            return;
        }

        inputDiag.focus();
        escribirEnInput(inputDiag, limpioCie);

        let panelDiag = null;
        for (let i = 0; i < 30; i++) {
            panelDiag = document.querySelector('.mat-autocomplete-panel');
            if (panelDiag && panelDiag.querySelector('mat-option')) break;
            await sleep(100);
        }

        if (!panelDiag) {
            console.warn("[Tampermonkey] El buscador de diagnóstico no desplegó opciones.");
            escribirEnInput(inputDiag, "");
            inputDiag.blur();
            return;
        }

        const opciones = panelDiag.querySelectorAll('mat-option');
        let opcionExacta = null;

        for (let opt of opciones) {
            const textoOpcion = (opt.textContent || "").trim().toUpperCase();

            if (textoOpcion.startsWith(limpioCie) || textoOpcion.includes(` ${limpioCie} `) || textoOpcion.includes(`${limpioCie} -`)) {
                opcionExacta = opt;
                break;
            }
        }

        if (opcionExacta) {
            console.log(`[Tampermonkey] Diagnóstico exacto encontrado (${opcionExacta.textContent.trim()}). Seleccionando...`);
            opcionExacta.click();
        } else {
            console.warn(`[Tampermonkey] No se encontró ninguna coincidencia exacta para "${limpioCie}". Se vacía el campo.`);
            escribirEnInput(inputDiag, "");
            inputDiag.dispatchEvent(new KeyboardEvent('keydown', { key: 'Escape', code: 'Escape', bubbles: true }));
            inputDiag.blur();
        }

        await sleep(400);
    }

    async function automatizarPrescriptor(medicoCodigo, medicoApellido) {
        console.log("[Tampermonkey] Configurando datos del médico prescriptor...");

        const componentePrescriptor = document.querySelector('app-prescriptor');
        if (!componentePrescriptor) {
            console.warn("[Tampermonkey] No se encontró el componente <app-prescriptor>.");
            return;
        }

        const selectTipo = componentePrescriptor.querySelector('mat-form-field.tipo mat-select');
        if (!selectTipo) {
            console.error("[Tampermonkey] No se localizó el selector de Tipo de matrícula.");
            return;
        }

        selectTipo.click();

        let panelSelect = null;
        for (let i = 0; i < 20; i++) {
            panelSelect = document.querySelector('.mat-select-panel, cdk-overlay-pane');
            if (panelSelect && panelSelect.querySelector('mat-option')) break;
            await sleep(100);
        }

        if (!panelSelect) {
            console.error("[Tampermonkey] No se desplegaron las opciones para Tipo de matrícula.");
            return;
        }

        const opciones = panelSelect.querySelectorAll('mat-option');
        let opcionLaPampa = null;

        for (let opt of opciones) {
            if (opt.textContent.trim().toUpperCase().includes('LA PAMPA')) {
                opcionLaPampa = opt;
                break;
            }
        }

        if (opcionLaPampa) {
            console.log("[Tampermonkey] Opción 'LA PAMPA' localizada. Seleccionando...");
            opcionLaPampa.click();
            await sleep(300);

            const inputMatricula = componentePrescriptor.querySelector('mat-form-field.matricula input');
            const inputRazonSocial = componentePrescriptor.querySelector('mat-form-field.razon_social input');

            if (!inputMatricula || !inputRazonSocial) {
                console.error("[Tampermonkey] No se encontraron los campos de texto para Matrícula o Razón Social.");
                return;
            }

            console.log(`[Tampermonkey] Escribiendo Matrícula: ${medicoCodigo} y Razón Social: ${medicoApellido}`);
            inputMatricula.focus();
            escribirEnInput(inputMatricula, String(medicoCodigo).trim());

            inputRazonSocial.focus();
            escribirEnInput(inputRazonSocial, String(medicoApellido).trim());
            inputRazonSocial.blur();
            await sleep(300);

            const botonBuscar = componentePrescriptor.querySelector('app-button.boton button, button[name="button"]');
            if (!botonBuscar || botonBuscar.disabled) {
                console.warn("[Tampermonkey] El botón 'BUSCAR PRESCRIPTOR' no está disponible o quedó deshabilitado.");
                return;
            }

            console.log("[Tampermonkey] Presionando botón 'BUSCAR PRESCRIPTOR'...");
            botonBuscar.click();

            console.log("[Tampermonkey] Esperando tabla de resultados...");
            let tablaMedicos = null;
            for (let i = 0; i < 30; i++) {
                tablaMedicos = componentePrescriptor.querySelector('mat-table');
                if (tablaMedicos && tablaMedicos.querySelector('mat-row')) break;
                await sleep(100);
            }

            if (!tablaMedicos) {
                console.warn("[Tampermonkey] No apareció la tabla de resultados.");
                return;
            }

            // Cantidad de filas
            const filasMedicos = tablaMedicos.querySelectorAll('mat-row');
            console.log(`[Tampermonkey] Filas encontradas: ${filasMedicos.length}`);

            // Si hay EXACTAMENTE una sola opción, se selecciona
            if (filasMedicos.length === 1) {
                const filaUnica = filasMedicos[0];

                const labelRadio = filaUnica.querySelector('label.mat-radio-label');
                if (labelRadio) {
                    console.log("[Tampermonkey] Clickeando el label del radio button...");
                    labelRadio.click();
                }
            }
        } else {
            console.warn("[Tampermonkey] No se encontró la opción 'LA PAMPA'. Cancelando.");
            const overlay = document.querySelector('.cdk-overlay-backdrop');
            if (overlay) overlay.click();

            const inputMatricula = componentePrescriptor.querySelector('mat-form-field.matricula input');
            const inputRazonSocial = componentePrescriptor.querySelector('mat-form-field.razon_social input');
            if (inputMatricula) escribirEnInput(inputMatricula, "");
            if (inputRazonSocial) escribirEnInput(inputRazonSocial, "");
        }

        await sleep(400);
    }

    async function cargarCodigosEnFormulario(listaCodigos) {
        await automatizarEfectorYEspecialidad();
        await sleep(200);

        await automatizarMarcaGuardia();
        await sleep(600);

        let codigosFallidos = [];

         for (let i = 0; i < listaCodigos.length; i++) {
            const item = listaCodigos[i];
            const codigoFinal = formatearCodigoPrestacion(item.codigo);
            const cantidadFinal = item.repeticiones || 1;

            const inputPrestacion = document.querySelector('input[aria-label="Código o descripción de prestación"]');
            if (!inputPrestacion) {
                console.error("No se encontró el campo para ingresar el código.");
                break;
            }

            inputPrestacion.focus();
            escribirEnInput(inputPrestacion, codigoFinal);

            let panelOpciones = null;
            for (let intentos = 0; intentos < 30; intentos++) {
                panelOpciones = document.querySelector('.mat-autocomplete-panel');
                if (panelOpciones && panelOpciones.querySelector('mat-option')) {
                    break;
                }
                await sleep(100);
            }

            if (!panelOpciones) {
                console.warn(`[Tampermonkey] No se desplegó el panel para: ${codigoFinal}`);
                codigosFallidos.push(`${codigoFinal} (${item.nombre || 'Sin nombre'} - No desplegó opciones)`);

                escribirEnInput(inputPrestacion, "");
                inputPrestacion.dispatchEvent(new KeyboardEvent('keydown', { key: 'Escape', code: 'Escape', bubbles: true }));
                inputPrestacion.blur();
                await sleep(500);
                continue;
            }

            const opciones = panelOpciones.querySelectorAll('mat-option');
            let opcionEncontrada = null;

            for (let opt of opciones) {
                const textoOpcion = opt.textContent || "";
                if (textoOpcion.includes(codigoFinal)) {
                    opcionEncontrada = opt;
                    break;
                }
            }

            if (opcionEncontrada) {
                opcionEncontrada.click();

                let seLimpio = false;
                for (let esperas = 0; esperas < 20; esperas++) {
                    if (inputPrestacion.value === "") {
                        seLimpio = true;
                        break;
                    }
                    await sleep(100);
                }

                if (!seLimpio) {
                    codigosFallidos.push(`${codigoFinal} (${item.nombre || 'Sin nombre'} - Error al confirmar selección)`);
                    escribirEnInput(inputPrestacion, "");
                    inputPrestacion.dispatchEvent(new KeyboardEvent('keydown', { key: 'Escape', code: 'Escape', bubbles: true }));
                    inputPrestacion.blur();
                    await sleep(500);
                    continue;
                }

                if (cantidadFinal > 1) {
                    await modificarCantidadDeCodigo(codigoFinal, cantidadFinal);
                }

            } else {
                console.warn(`[Tampermonkey] Código ${codigoFinal} no coincide con ninguna opción del panel.`);
                codigosFallidos.push(`${codigoFinal} (${item.nombre || 'Sin nombre'} - No encontrado en la lista de opciones)`);

                escribirEnInput(inputPrestacion, "");
                inputPrestacion.dispatchEvent(new KeyboardEvent('keydown', { key: 'Escape', code: 'Escape', bubbles: true }));
                inputPrestacion.blur();

                await sleep(600);
            }

            await sleep(500);
        }
         mostrarModalErrores(codigosFallidos);
    }

    function miAccionPersonalizada(numeroAfiliado) {
        //const urlApi = `http://localhost:8001/api/v2/laboratorio/paciente/${numeroAfiliado}/codigos?obra=125`;
        const urlApi = `https://srapp.diagnosis.com.ar/api/v2/laboratorio/paciente/${numeroAfiliado}/codigos?obra=125`;

        GM_xmlhttpRequest({
            method: "GET",
            url: urlApi,
            headers: { "Content-Type": "application/json" },
            onload: function(response) {
                if (response.status === 200) {
                    try {
                        const jsonRespuesta = JSON.parse(response.responseText);
                        if (jsonRespuesta && jsonRespuesta.resultCodigos && jsonRespuesta.resultCodigos.length > 0) {
                            datosMedicosTemporales.codigoDiagnostico = jsonRespuesta.diagnostico;
                            datosMedicosTemporales.medicoCodigo = jsonRespuesta.medicoCodigo;
                            datosMedicosTemporales.medicoApellido = jsonRespuesta.medicoApellido;

                            // chequear si está el código 662003, si no mostrar cartel de error
                            const listaCodigos = jsonRespuesta.resultCodigos;
                            let codigoPresente = false
                            for (let i = 0; i < listaCodigos.length; i++) {
                                const item = listaCodigos[i];
                                if(String(item.codigo) === "2003"){
                                    codigoPresente = true
                                    break;
                                }
                            }
                            if(codigoPresente){
                                cargarCodigosEnFormulario(jsonRespuesta.resultCodigos);
                            } else {
                                mostrarErrorCodigoFaltante()
                            }
                        } else {
                            alert("No se encontraron códigos pendientes para este afiliado.");
                        }
                    } catch (e) {
                        console.error("[Tampermonkey] Error de parseo JSON:", e);
                    }
                } else {
                    try {
                        const jsonError = JSON.parse(response.responseText);

                        if (jsonError && jsonError.error) {
                            alert("Error: " + jsonError.error);
                        } else {
                            alert("Verifique que tiene la sesión del DWEB iniciada \nError del servidor: " + response.status);
                        }
                    } catch (e) {
                        alert("Error " + response.status + ": " + response.statusText);
                    }
                }
            },
            onerror: function() {
                alert("Error de red. Verificá tu servidor local.");
            }
        });
    }

    function extraerAfiliado(texto) {
        const match = texto.match(/Credencial:\s*([0-9\/]+)/i);
        if (match && match[1]) {
            return match[1].replace('/', '').trim();
        }
        return null;
    }

    function crearBotonEnAlerta(alertaElement) {
        const textoCartel = alertaElement.textContent || "";
        const nroAfiliado = extraerAfiliado(textoCartel);

        if (!nroAfiliado) return;

        // Buscamos si ya existe un botón inyectado previamente
        const botonExistente = alertaElement.parentElement.querySelector('.mi-boton-alerta-sancor');

        if (botonExistente) {
            // SI EXISTE: Verificamos si tiene el número del paciente actual guardado en su atributo personalizado
            if (botonExistente.getAttribute('data-afiliado') === nroAfiliado) {
                // Si el número coincide, no hacemos nada (ya está bien dibujado)
                return;
            } else {
                // SI NO COINCIDE (cambió el paciente): Borramos el botón viejo para poner el nuevo
                console.log(`[Tampermonkey] Detectado cambio de paciente (${botonExistente.getAttribute('data-afiliado')} ➡️ ${nroAfiliado}). Actualizando botón...`);
                botonExistente.remove();
            }
        }

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.innerText = `Cargar Datos y Códigos de Afiliado: ${nroAfiliado} ⏩`;
        btn.className = 'mi-boton-alerta-sancor';

        btn.setAttribute('data-afiliado', nroAfiliado);

        btn.style.marginTop = '10px';
        btn.style.marginBottom = '10px';
        btn.style.marginLeft = '8px';
        btn.style.padding = '12px 24px';
        btn.style.backgroundColor = '#364962';
        btn.style.color = 'white';
        btn.style.border = 'none';
        btn.style.borderRadius = '8px';
        btn.style.cursor = 'pointer';
        btn.style.fontWeight = 'bold';
        btn.style.boxShadow = '0px 4px 6px rgba(0,0,0,0.15)';
        btn.style.display = 'block';

        const colorOriginal = '#364962';
        const colorHover = '#666';

        btn.addEventListener('mouseenter', () => {
            btn.style.backgroundColor = colorHover;
            btn.style.transition = 'background-color 0.2s ease';
        });
        btn.addEventListener('mouseleave', () => {
            btn.style.backgroundColor = colorOriginal;
        });

        btn.addEventListener('click', (e) => {
            e.preventDefault();
            e.stopPropagation();
            miAccionPersonalizada(nroAfiliado);
        });

        alertaElement.after(btn);
    }

    setInterval(() => {
        const alertas = document.querySelectorAll('app-alert');
        alertas.forEach(alerta => {
            if (alerta.textContent && alerta.textContent.includes('HABILITADO')) {
                crearBotonEnAlerta(alerta);
            }
        });
    }, 1000);

